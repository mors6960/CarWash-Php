# ─── Database ───────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=carwash
DB_USER=root
DB_PASS=

# ─── Internal API Key (Power BI uses this) ───────────────
API_KEY=

# ─── Sonny's CarWash API ─────────────────────────────────
SONNYS_API_URL=https://trigonapi.sonnyscontrols.com/v1
SONNYS_SANDBOX_URL=https://sandboxapi.sonnyscontrols.com/v1
SONNYS_API_KEY=
SONNYS_API_ID=
SONNYS_SITE_ID=STOCK

# ─── Rippling API ────────────────────────────────────────
RIPPLING_API_URL=https://api.rippling.com
RIPPLING_API_TOKEN=

# ─── Weather API (OpenWeatherMap) ────────────────────────
WEATHER_API_URL=https://api.openweathermap.org/data/2.5
WEATHER_API_KEY=
WEATHER_CITY=Stockton,US

# ─── App ─────────────────────────────────────────────────
APP_ENV=local
APP_DEBUG=false
